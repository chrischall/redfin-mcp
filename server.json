{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.chrischall/redfin-mcp",
  "description": "Redfin real-estate for Claude \u2014 search, property details, Zestimates, saved searches & homes",
  "repository": {
    "url": "https://github.com/chrischall/redfin-mcp",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "redfin-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "REDFIN_WS_PORT",
          "description": "Override the fetchproxy WebSocket port (default 37149).",
          "isRequired": false,
          "format": "string"
        }
      ]
    }
  ]
}
