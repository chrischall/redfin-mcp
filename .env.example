# No credentials needed. Auth lives in your signed-in redfin.com browser
# tab via the fetchproxy extension. This file is a marker only.
#
# Optional overrides:
# REDFIN_WS_PORT=37149                               # fetchproxy WebSocket port
# REDFIN_COMMUNITIES_FILE=/path/to/communities.json  # community vocabulary (JSON string array)
# REDFIN_DEBUG=1                                      # verbose fetchproxy transport logging to stderr
